# Google Cloud Settings
export GOOGLE_GENAI_USE_VERTEXAI=1
export GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
export GOOGLE_CLOUD_LOCATION="your-gcp-location"

# LLM configuration
export GEMINI_API_KEY=your-gemini-api-key
export LLM_MODEL_NAME=gemini-2.5-flash
export EMBEDDING_MODEL_NAME=gemini-embedding-001
export EMBEDDING_DIM=3072

# Working directory for LightRAG data files (optional, a temp directory is used if unset).
# export LIGHTRAG_WORKING_DIR=/path/to/your/lightrag/data

# Google Cloud Spanner configuration
export SPANNER_INSTANCE=your-spanner-instance
export SPANNER_DATABASE=your-spanner-database
