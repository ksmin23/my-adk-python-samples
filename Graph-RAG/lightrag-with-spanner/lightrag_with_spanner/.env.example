# Google Cloud Settings
export GOOGLE_GENAI_USE_VERTEXAI=1
export GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
export GOOGLE_CLOUD_LOCATION="your-gcp-location"

# LLM configuration
export GEMINI_API_KEY=your-gemini-api-key
export LLM_MODEL_NAME=gemini-2.5-flash
export EMBEDDING_MODEL_NAME=gemini-embedding-001
export EMBEDDING_DIM=3072

# LightRAG Storage configuration
# Storage backend type: "spanner" (Cloud Spanner) or "default" (local file-based)
#   - spanner : uses SpannerKVStorage, SpannerVectorStorage, SpannerGraphStorage, SpannerDocStatusStorage
#   - default : uses default local storage (JsonKVStorage, NanoVectorDBStorage, NetworkXStorage)
export LIGHTRAG_STORAGE_TYPE=spanner

# Working directory for LightRAG data files.
# Required when LIGHTRAG_STORAGE_TYPE=default (local storage persists data here).
# Optional when LIGHTRAG_STORAGE_TYPE=spanner (a temp directory is used if unset).
# export LIGHTRAG_WORKING_DIR=/path/to/your/lightrag/data

# Google Cloud Spanner configuration (required when LIGHTRAG_STORAGE_TYPE=spanner)
export SPANNER_INSTANCE=your-spanner-instance
export SPANNER_DATABASE=your-spanner-database
