# Google Cloud Settings
export GOOGLE_GENAI_USE_VERTEXAI=true
export GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
export GOOGLE_CLOUD_LOCATION="your-gcp-location"

# LLM configuration
export LLM_MODEL_NAME=gemini-2.5-flash
export EMBEDDING_MODEL_NAME=gemini-embedding-001
export EMBEDDING_DIM=1536
export EMBEDDING_MAX_TOKEN_SIZE=2048

# Working directory for LightRAG data files (optional, a temp directory is used if unset).
# export LIGHTRAG_WORKING_DIR=/path/to/your/lightrag/data

# Workspace name for multi-tenant isolation in Spanner storage (default: "lightrag")
export LIGHTRAG_WORKSPACE=lightrag

# Number of top entities/relationships to retrieve per vector search (default: 10)
export LIGHTRAG_QUERY_TOP_K=10
# Minimum cosine similarity threshold for vector search results; higher values return fewer but more relevant results (default: 0.5)
export LIGHTRAG_COSINE_THRESHOLD=0.5

# Google Cloud Spanner configuration
export SPANNER_INSTANCE=your-spanner-instance
export SPANNER_DATABASE=your-spanner-database
