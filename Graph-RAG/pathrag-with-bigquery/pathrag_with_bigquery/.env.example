# Google Cloud Settings
export GOOGLE_GENAI_USE_VERTEXAI=1
export GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
export GOOGLE_CLOUD_LOCATION="your-gcp-location"

# LLM configuration
export GEMINI_API_KEY=your-gemini-api-key
export LLM_MODEL_NAME=gemini/gemini-2.5-flash
export EMBEDDING_MODEL_NAME=gemini/gemini-embedding-001
export EMBEDDING_DIM=1536
export EMBEDDING_MAX_TOKEN_SIZE=2048

# PathRAG Working directory for data files.
# Optional — a temp directory is used if unset.
# export PATHRAG_WORKING_DIR=/path/to/your/pathrag/data

# Google Cloud BigQuery configuration
export BIGQUERY_PROJECT=your-bigquery-project-id
export BIGQUERY_DATASET=pathrag
export BIGQUERY_GRAPH_NAME=pathrag_knowledge_graph
