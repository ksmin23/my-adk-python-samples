# Google Cloud Settings
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="your-gcp-location"

# LLM configuration
GEMINI_API_KEY=your-gemini-api-key
LLM_MODEL_NAME=gemini/gemini-2.5-flash
EMBEDDING_MODEL_NAME=gemini/gemini-embedding-001
EMBEDDING_DIM=3072

# PathRAG Storage configuration
# Storage backend type: "spanner" (Cloud Spanner) or "default" (local file-based)
#   - spanner : uses SpannerKVStorage, SpannerVectorDBStorage, SpannerGraphStorage
#   - default : uses JsonKVStorage, NanoVectorDBStorage, NetworkXStorage
PATHRAG_STORAGE_TYPE=spanner

# Working directory for PathRAG data files.
# Required when PATHRAG_STORAGE_TYPE=default (local storage persists data here).
# Optional when PATHRAG_STORAGE_TYPE=spanner (a temp directory is used if unset).
# PATHRAG_WORKING_DIR=/path/to/your/pathrag/data

# Google Cloud Spanner configuration (required when PATHRAG_STORAGE_TYPE=spanner)
SPANNER_INSTANCE=your-spanner-instance
SPANNER_DATABASE=your-spanner-database